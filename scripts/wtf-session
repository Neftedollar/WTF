#!/usr/bin/env bash
# wtf-session — the session wrapper the display manager launches instead of the
# raw WTF host. It guarantees the user is never stuck at a frozen/black screen:
#
#   - captures the host's stdout+stderr to a rotating log under
#     $XDG_STATE_HOME/wtf (default ~/.local/state/wtf),
#   - restores the console on EVERY exit (kbd_mode -s / stty sane / clear),
#   - bounded restart loop (3 restarts within 10s) on abnormal exit,
#   - escalates to safe-mode (WTF_SAFE_MODE=1) for one more try,
#   - then drops to a terminal or $SHELL as a last-resort escape hatch.
#
# Strict: set -u (NOT -e — the host return code is managed explicitly). Every
# external command is guarded with `command -v`.

set -u

HOST="${WTF_HOST:-/usr/local/bin/wtf}"

# Portals (screenshot/screencast) route by XDG_CURRENT_DESKTOP. GDM/SDDM set it
# from the .desktop's DesktopNames; greetd/ly/TTY launches do NOT — export a
# default here so wtf-portals.conf is selected on every launch path.
export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-wtf}"
export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"

# ${HOME:-/tmp}: under set -u an unset HOME (greetd misconfig, bare systemd
# unit) would kill the script HERE, before any trap — a black screen with no
# log. /tmp always exists.
STATE_DIR="${XDG_STATE_HOME:-${HOME:-/tmp}/.local/state}/wtf"
mkdir -p "$STATE_DIR" 2>/dev/null || true
if command -v date >/dev/null 2>&1; then
	STAMP="$(date +%Y%m%d-%H%M%S 2>/dev/null || echo unknown)"
else
	STAMP="unknown"
fi
LOG="$STATE_DIR/session-$STAMP.log"
# Logging must never gate the COMPOSITOR: if the log file isn't writable
# (read-only $HOME, full disk), `"$HOST" >>"$LOG"` would fail the redirection
# and never exec the host — a healthy WM refused because logging failed.
if ! : >>"$LOG" 2>/dev/null; then
	LOG=/dev/null
fi

log() {
	if command -v date >/dev/null 2>&1; then
		printf '[%s] %s\n' "$(date +%H:%M:%S 2>/dev/null || echo '--:--:--')" "$*" >>"$LOG" 2>/dev/null || true
	else
		printf '%s\n' "$*" >>"$LOG" 2>/dev/null || true
	fi
}

# Keep only the newest ~10 session logs.
prune_logs() {
	if ! command -v find >/dev/null 2>&1; then
		return 0
	fi
	if ! command -v sort >/dev/null 2>&1; then
		return 0
	fi
	find "$STATE_DIR" -maxdepth 1 -type f -name 'session-*.log' -printf '%T@ %p\n' 2>/dev/null \
		| sort -n \
		| head -n -10 \
		| cut -d' ' -f2- \
		| while IFS= read -r old; do
			rm -f -- "$old" 2>/dev/null || true
		done
}

# restore_console — idempotent; runs on EVERY exit so the user is never wedged.
# Each step is guarded by command -v and swallows errors (harmless on a pty).
restore_console() {
	if command -v kbd_mode >/dev/null 2>&1; then
		kbd_mode -s 2>/dev/null || true        # raw -> XLATE
	fi
	if command -v stty >/dev/null 2>&1; then
		stty sane 2>/dev/null || true          # line discipline on controlling tty
	fi
	if command -v clear >/dev/null 2>&1; then
		clear 2>/dev/null || true              # repaint
	fi
	# chvt deliberately NOT executed: a wrong VT switch can worsen a wedge.
	# If ever needed, it would go here, guarded:
	#   if command -v chvt >/dev/null 2>&1; then chvt 1 2>/dev/null || true; fi
}

# Restore on normal exit and on explicit `exit`. A session-manager SIGTERM
# becomes a clean wrapper exit (0) that still runs the EXIT restore; the host
# runs in the FOREGROUND so it receives the same SIGTERM, runs its own graceful
# teardown (DRM released) and returns before the wrapper proceeds — no race.
trap restore_console EXIT
trap 'exit 0' INT TERM

run_fallback() {
	restore_console
	log "entering fallback (terminal or shell)"
	# A terminal emulator needs a LIVE display server — and the compositor just
	# died. Under a display manager there is nothing to connect to: foot/kitty
	# would exit instantly and the session ends silently at the greeter. Only
	# try them if some display still exists (nested/dev runs).
	if [ -n "${WAYLAND_DISPLAY:-}" ] || [ -n "${DISPLAY:-}" ]; then
		for term in foot kitty alacritty xterm; do
			if command -v "$term" >/dev/null 2>&1; then
				exec "$term"
			fi
		done
	fi
	printf 'WTF failed; see %s.\n' "$LOG" >&2
	# An interactive shell only makes sense on a real TTY (VT launch). Under a
	# DM stdin is /dev/null: the shell would read EOF and exit instantly — and
	# $SHELL may even be nologin. Exit 1 instead so the DM returns to the
	# greeter cleanly.
	if [ -t 0 ]; then
		printf 'Dropping to a shell.\n' >&2
		exec "${SHELL:-/bin/sh}"
	fi
	exit 1
}

prune_logs
log "wtf-session starting; host=$HOST"

MAX_RESTARTS=3
WINDOW=10
# Lifetime cap: the sliding window alone never escalates a SLOW crasher (a host
# that runs >10s then dies resets the window every lap => infinite restart loop
# + an unbounded log). After this many total abnormal exits, escalate no matter
# the spacing.
MAX_TOTAL=20
# Consecutive quick (rc=42, <8s-lived) reloads tolerated before the loop guard
# routes to the crash path. Bounds an instant boot loop while allowing rapid
# hand-driven iteration.
MAX_FAST_RELOADS=5
fast_reloads=0
total=0
attempts=0
if command -v date >/dev/null 2>&1; then
	window_start="$(date +%s 2>/dev/null || echo 0)"
else
	window_start=0
fi

while true; do
	if [ ! -x "$HOST" ]; then
		log "host not executable: $HOST"
		printf 'WTF host not found at %s\n' "$HOST" >&2
		run_fallback
	fi

	log "launching host (attempt window count=$attempts)"
	if command -v date >/dev/null 2>&1; then
		host_start="$(date +%s 2>/dev/null || echo 0)"
	else
		host_start=0
	fi
	"$HOST" >>"$LOG" 2>&1
	rc=$?
	restore_console
	log "host exited rc=$rc"

	if [ "$rc" -eq 0 ]; then
		log "clean exit — leaving"
		exit 0
	fi

	# Intentional session reload (`wtfctl restart` / wtf-reload): re-exec the host
	# so a freshly installed build is picked up WITHOUT counting as a crash and
	# WITHOUT a logout/reboot.
	#
	# LOOP-GUARDED: a build that hits the restart path at STARTUP — a stray
	# `exit 42` / `wtfctl restart` in config.fsx or StartupApps, or a client
	# spamming the control socket — would otherwise re-exec instantly forever, an
	# unbounded loop that never escalates to safe mode. We still honor a QUICK
	# manual reload (rapid shader/config iteration re-exec's within seconds), but
	# count CONSECUTIVE fast (<8s-lived) rc=42s; after MAX_FAST_RELOADS of them we
	# stop trusting it and fall through to the crash path (safe-mode → fallback).
	# A reload after a healthy-length session resets the streak.
	if [ "$rc" -eq 42 ]; then
		if command -v date >/dev/null 2>&1; then
			host_now="$(date +%s 2>/dev/null || echo 0)"
		else
			host_now=0
		fi
		uptime="$((host_now - host_start))"
		if [ "$uptime" -ge 8 ]; then
			fast_reloads=0
		else
			fast_reloads="$((fast_reloads + 1))"
		fi
		if [ "$fast_reloads" -le "$MAX_FAST_RELOADS" ]; then
			log "session reload (rc=42, uptime ${uptime}s, fast streak ${fast_reloads}/${MAX_FAST_RELOADS}) — re-exec fresh build"
			attempts=0
			window_start="$host_now"
			continue
		fi
		log "rc=42 loop guard: ${fast_reloads} fast reloads in a row — treating as a crash"
		# fall through to crash accounting below (-> safe mode -> fallback)
	fi

	# Sliding-window restart accounting.
	if command -v date >/dev/null 2>&1; then
		now="$(date +%s 2>/dev/null || echo 0)"
	else
		now=0
	fi
	if [ "$((now - window_start))" -gt "$WINDOW" ]; then
		attempts=0
		window_start="$now"
	fi
	attempts="$((attempts + 1))"
	total="$((total + 1))"

	if [ "$total" -gt "$MAX_TOTAL" ]; then
		log "lifetime restart cap ($MAX_TOTAL) exceeded — escalating"
	elif [ "$attempts" -le "$MAX_RESTARTS" ]; then
		log "abnormal exit — restart $attempts/$MAX_RESTARTS (total $total/$MAX_TOTAL)"
		continue
	fi

	# Cap exceeded: one escalation attempt in safe-mode.
	log "restart cap exceeded — escalating to WTF_SAFE_MODE=1"
	if [ ! -x "$HOST" ]; then
		log "host not executable for safe-mode: $HOST"
		run_fallback
	fi
	WTF_SAFE_MODE=1 "$HOST" >>"$LOG" 2>&1
	rc=$?
	restore_console
	log "safe-mode host exited rc=$rc"
	if [ "$rc" -eq 0 ]; then
		exit 0
	fi
	break
done

run_fallback
